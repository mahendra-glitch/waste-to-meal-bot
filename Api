// /api/generate.js
export default async function handler(req, res) {
    const { ingredients, isLazy } = JSON.parse(req.body);
    const API_KEY = process.env.GEMINI_API_KEY; // This pulls from Vercel's secret settings

    const prompt = `Act as a chef. Create a recipe using: ${ingredients}. 
                    ${isLazy ? "Must be under 15 mins." : ""}
                    Format as HTML: <h3>Title</h3><p>Steps...</p>`;

    const response = await fetch(`https://generativelanguage.googleapis.com/v1beta/models/gemini-1.5-flash:generateContent?key=${API_KEY}`, {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ contents: [{ parts: [{ text: prompt }] }] })
    });

    const data = await response.json();
    res.status(200).json(data);
}
